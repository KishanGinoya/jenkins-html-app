pipeline {
    agent any

    stages {

        stage('Show Files') {
            steps {
                sh 'ls'
            }
        }

        stage('Docker Build') {
            steps {
                sh 'docker build -t my-nginx-app .'
            }
        }

        stage('Run Container') {
    steps {
        sh '''
        docker stop my-container || true
        docker rm my-container || true
        docker run -d -p 8081:80 --name my-container my-nginx-app
        '''
    }
}
stage('Debug Docker') {
    steps {
        sh 'whoami'
        sh 'groups'
        sh 'docker ps'
    }
}

    }
}
