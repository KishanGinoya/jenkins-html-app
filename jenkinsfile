pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git 'https://github.com/KishanGinoya/jenkins-html-app.git'
            }
        }

        stage('Show Files') {
            steps {
                sh 'ls'
            }
        }

        stage('Read HTML') {
            steps {
                sh 'cat index.html'
            }
        }

    }
}
