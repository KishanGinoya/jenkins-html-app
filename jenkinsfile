pipeline {
    agent any

    stages {

        stage('Show Files') {
            steps {
                sh 'ls'
            }
        }

        stage('Docker Build') {
            steps {
                sh 'docker build -t my-nginx-app .'
            }
        }

        stage('Run Container') {
            steps {
                sh 'docker run -d -p 8081:80 my-nginx-app'
            }
        }
stage('Debug Docker') {
    steps {
        sh 'whoami'
        sh 'groups'
        sh 'docker ps'
    }
}

    }
}
